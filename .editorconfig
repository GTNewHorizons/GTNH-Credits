# This is the universal Text Editor Configuration
# for all GTNewHorizons projects
# See: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Windows batch and ini files
[*.{bat,ini}]
end_of_line = crlf

# Files that should use 2-space indent
[*.{dtd,json,info,mcmeta,sh,svg,xml,xsd,xsl,yaml,yml}]
indent_size = 2

# Markdown and lang files - 2 spaces + no trailing whitespace trim
[*.{lang,md}]
indent_size = 2
trim_trailing_whitespace = false
